[Unit]
Description=BL-FMO-LITE FM Monitoring
After=network.target

[Service]
Type=simple
User=graffiti
WorkingDirectory=/home/graffiti/bl-fmo-lite
Environment="PATH=/home/graffiti/bl-fmo-lite/venv/bin:/usr/bin:/bin"
ExecStart=/home/graffiti/bl-fmo-lite/venv/bin/gunicorn \
    --bind 0.0.0.0:5000 \
    --workers 1 \
    --worker-class gthread \
    --threads 8 \
    --timeout 60 \
    app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
